# ── Neurix CRM ──
# Application
APP_NAME=Neurix CRM
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=https://crm.wbtech.dev

# ── Supabase ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Auth ──
SESSION_DURATION_DAYS=14
TWO_FACTOR_ENABLED=true

# ── n8n Integration ──
# API key for the unified n8n webhook endpoint (POST /api/n8n/webhook).
# Defina no container/serviço do BACKEND (FastAPI), não só no n8n.
# Nome aceito: N8N_API_KEY (recomendado), ou n8n_api_key / N8N_APIKEY.
# Se o log de startup avisar "N8N_API_KEY não configurada", a variável não chegou neste processo.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
N8N_API_KEY=

# ── Neurix HQ (consulta outbound às instâncias n8n) ──
# JSON em uma linha. Cada instância precisa de API key com scopes:
# insights:read, workflow:read, execution:read, execution:list
# N8N_INSTANCES=[{"id":"neurix","label":"Neurix","base_url":"https://n8n.example.com","api_key":"n8n_api_..."},{"id":"wbtech","label":"WB Tech","base_url":"https://n8n2.example.com","api_key":"n8n_api_..."}]
N8N_INSTANCES=
HQ_CACHE_TTL_SECONDS=300

# ── Uazapi (WhatsApp Integration) ──
# Base URL pública do FastAPI (webhook: {PUBLIC_API_BASE_URL}/api/webhooks/uazapi?secret=...)
PUBLIC_API_BASE_URL=https://crm.wbtech.dev
UAZAPI_URL=https://neurix.uazapi.com
UAZAPI_ADMIN_TOKEN=
UAZAPI_INSTANCE_TOKEN=
UAZAPI_WEBHOOK_SECRET=

# ── SMTP ──
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
