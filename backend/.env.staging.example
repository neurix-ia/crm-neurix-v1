# ── Neurix CRM — STAGING (template, sem secrets reais) ──
# Copie para .env.local apenas em máquina de dev; em Dokploy use a UI de env vars.
# NUNCA commitar arquivo com valores reais.

APP_NAME=Neurix CRM [STAGING]
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=https://crm-staging.wbtech.dev

# Supabase staging — instância separada de produção
SUPABASE_URL=
SUPABASE_PUBLIC_URL=https://crm-supabase-staging.wbtech.dev
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Redis staging — instância separada
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

SESSION_DURATION_DAYS=14
TWO_FACTOR_ENABLED=false

# Chave nova — não reutilizar N8N_API_KEY de produção
N8N_API_KEY=

PUBLIC_API_BASE_URL=https://crm-staging.wbtech.dev

# WhatsApp desligado em staging por padrão
UAZAPI_URL=
UAZAPI_ADMIN_TOKEN=
UAZAPI_INSTANCE_TOKEN=
UAZAPI_WEBHOOK_SECRET=

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
